# Database Configuration
DB_URL=jdbc:postgresql://mediflow-db:5432/mediflow_db
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# JWT Configuration
# Ensure your JWT secret is genuinely random and at least 256 bits (32+ characters) long
JWT_SECRET=your_super_secret_jwt_key_that_is_long_enough_for_security
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:4200

#API Configuration
API_kEY="your_api_key_here"